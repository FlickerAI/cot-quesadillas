---
// index.astro
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cotización - R&G Solutions</title>
    <!-- Tailwind CSS -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <!-- Phosphor Icons -->
    <script is:inline src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        gold: {
                            400: '#FBBF24',
                            500: '#D4AF37',
                            600: '#B8860B',
                        },
                        brandRed: {
                            500: '#E63946',
                            600: '#DC2626',
                        },
                        dark: {
                            950: '#050505',
                            900: '#0A0A0A',
                            800: '#171717',
                            700: '#262626',
                            600: '#404040',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background-color: white !important;
                color: black !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            .print-break-inside-avoid {
                break-inside: avoid;
            }
            @page {
                margin: 1cm;
            }
            /* Override dark mode colors for print */
            .print\:text-slate-900 { color: #0f172a !important; }
            .print\:text-slate-600 { color: #475569 !important; }
            .print\:bg-white { background-color: white !important; }
            .print\:border-slate-200 { border-color: #e2e8f0 !important; }
            .print\:shadow-none { box-shadow: none !important; }
        }
        
        /* Subtle glow effects for the premium feel */
        .glow-gold {
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.15);
        }
        .glow-red {
            box-shadow: 0 0 15px rgba(230, 57, 70, 0.15);
        }
    </style>
</head>
<body class="bg-dark-900 text-neutral-300 font-sans antialiased pb-20">

    <!-- Navbar / Header -->
    <header class="bg-dark-950 text-white py-6 shadow-md border-b border-dark-800 print:bg-white print:text-black print:border-b-2 print:border-black print:shadow-none">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center">
            <div class="flex items-center gap-3">
                <i class="ph ph-devices text-gold-500 text-3xl"></i>
                <div>
                    <h1 class="text-2xl font-bold tracking-tight text-white print:text-black">R&G Solutions</h1>
                    <p class="text-xs text-gold-400 print:text-slate-600 tracking-wider uppercase">Soluciones Audiovisuales y Tecnológicas</p>
                </div>
            </div>
            <div class="mt-4 md:mt-0 text-center md:text-right">
                <p class="text-sm font-medium text-neutral-400 print:text-slate-600" id="current-date"></p>
                <button onclick="window.print()" class="no-print mt-2 inline-flex items-center gap-2 bg-brandRed-600 hover:bg-brandRed-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors print:hidden shadow-lg glow-red">
                    <i class="ph ph-printer text-lg"></i> Imprimir / PDF
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-6xl mx-auto px-6 mt-12 space-y-16 print:space-y-8 print:mt-6">
        
        <!-- Intro -->
        <section class="text-center max-w-3xl mx-auto">
            <h2 class="text-sm font-bold text-gold-500 uppercase tracking-widest mb-3">Propuesta Comercial</h2>
            <h3 class="text-3xl md:text-4xl font-extrabold text-white print:text-black mb-4">Cotización — Sistema Punto de Venta R&G</h3>
            <p class="text-lg text-neutral-400 print:text-slate-600 font-medium mb-8">Las Quilacas · Chilaquiles y alimentos preparados</p>
            
            <div class="bg-dark-800 p-8 rounded-2xl border border-dark-700 text-left print:bg-white print:border-none print:p-0">
                <p class="text-neutral-300 print:text-slate-700 leading-relaxed text-lg">
                    Gracias por considerar el Sistema Punto de Venta R&G Solutions para la operación de <strong class="text-gold-400 print:text-black">Las Quilacas</strong>.<br><br>
                    La presente propuesta está diseñada para facilitar el control de ventas, pedidos, productos e inventario, ayudando a mejorar la organización diaria del negocio y reducir errores operativos.
                </p>
            </div>
        </section>

        <!-- Objetivos -->
        <section class="print-break-inside-avoid">
            <div class="flex items-center gap-3 mb-8">
                <div class="p-2 bg-dark-800 rounded-lg border border-dark-700 print:border-none print:bg-transparent">
                    <i class="ph ph-crosshair text-gold-500 text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-white print:text-black">Objetivo del Sistema</h3>
            </div>
            <p class="text-neutral-400 print:text-slate-600 mb-6 text-lg">Implementar un sistema de punto de venta que permita:</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-lightning text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Registrar ventas y pedidos de forma rápida.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-list-dashes text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Llevar control de productos, categorías y precios.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-chart-bar text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Consultar reportes de ventas.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-check-circle text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Mejorar el control de operación diaria.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-shield-check text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Reducir errores en cobros y registros.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-trend-up text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Tener mayor claridad sobre ventas, productos más vendidos y movimientos del negocio.</p>
                </div>
            </div>
        </section>

        <!-- Inversión -->
        <section class="print-break-inside-avoid">
            <div class="flex items-center gap-3 mb-8">
                <div class="p-2 bg-dark-800 rounded-lg border border-dark-700 print:border-none print:bg-transparent">
                    <i class="ph ph-credit-card text-gold-500 text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-white print:text-black">Inversión</h3>
            </div>

            <div class="max-w-2xl mx-auto">
                <div class="bg-dark-950 rounded-2xl border-2 border-gold-500 overflow-hidden flex flex-col relative transform glow-gold print:bg-white print:border-slate-800 print:shadow-none">
                    <div class="p-8 bg-dark-800 border-b border-dark-700 text-center print:bg-slate-100 print:border-slate-200">
                        <h4 class="text-xl font-bold text-gold-400 print:text-black">Licencia de Software Punto de Venta R&G</h4>
                        <div class="mt-4 flex justify-center items-baseline gap-1">
                            <span class="text-4xl font-extrabold tracking-tight text-white print:text-black">$7,000</span>
                            <span class="text-sm font-semibold text-gold-400 print:text-slate-600">MXN</span>
                        </div>
                        <p class="text-xs text-gold-500/70 mt-2 uppercase tracking-wider font-semibold print:text-slate-500">Pago Único</p>
                    </div>
                    
                    <div class="p-8 flex-1 text-sm text-neutral-300 space-y-8 print:text-slate-700">
                        <!-- Incluye -->
                        <div>
                            <h5 class="font-bold text-white print:text-black mb-3 flex items-center gap-2"><i class="ph-fill ph-check-circle text-gold-500 text-lg"></i> Incluye:</h5>
                            <ul class="space-y-3 ml-7 list-disc marker:text-gold-500">
                                <li>Sistema Punto de Venta R&G.</li>
                                <li>Licencia permanente de uso.</li>
                                <li>Registro y control de ventas.</li>
                                <li>Catálogo de productos y categorías.</li>
                                <li>Control básico de inventario.</li>
                                <li>Reportes y estadísticas de ventas.</li>
                                <li>Configuración inicial básica.</li>
                                <li>Capacitación inicial para el uso del sistema.</li>
                                <li>Instalación del software en el equipo proporcionado por el cliente.</li>
                                <li>Soporte técnico básico remoto.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Condiciones Adicionales -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-10 print-break-inside-avoid">
            
            <!-- Columna Izquierda -->
            <div class="space-y-10">
                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-x-circle text-brandRed-500 text-xl"></i> No Incluye
                    </h3>
                    <ul class="space-y-3 text-sm text-neutral-300 print:text-slate-700">
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Tablet, impresora, cajón de dinero, bases, accesorios u otro hardware.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Configuración avanzada de inventario.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Carga masiva de productos.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Registro detallado de recetas, insumos o costos por platillo.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Personalizaciones especiales fuera de las funciones actuales del sistema.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Visitas técnicas presenciales posteriores a la instalación.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-brandRed-500 mt-1.5 shrink-0"></div>Actualizaciones mayores o módulos nuevos.</li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-shield-check text-gold-500 text-xl"></i> Garantía
                    </h3>
                    <p class="text-sm text-neutral-300 print:text-slate-700 mb-3">R&G Solutions garantiza el funcionamiento correcto del software conforme a las funciones establecidas en esta propuesta.</p>
                    <p class="text-sm text-neutral-300 print:text-slate-700">No se incluyen fallas ocasionadas por daños, virus, modificaciones no autorizadas, problemas del equipo del cliente, conexión a internet, sistemas operativos no compatibles o instalación de software externo que afecte el funcionamiento del sistema.</p>
                </div>
            </div>

            <!-- Columna Derecha -->
            <div class="space-y-10">
                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-gear text-gold-500 text-xl"></i> Configuración Avanzada
                    </h3>
                    <p class="text-sm text-neutral-300 print:text-slate-700 mb-3">La configuración avanzada podrá cotizarse por separado en caso de requerir:</p>
                    <ul class="space-y-3 text-sm text-neutral-300 print:text-slate-700">
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Alta masiva de productos.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Configuración detallada de inventario.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Registro de recetas e insumos.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Ajustes personalizados de operación.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Personalización de tickets.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Implementación en equipos adicionales.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Funciones nuevas o módulos especiales.</li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-headphones text-gold-500 text-xl"></i> Soporte y Actualizaciones
                    </h3>
                    <p class="text-sm text-neutral-300 print:text-slate-700 mb-3">La licencia incluye soporte técnico básico remoto para incidencias relacionadas con el funcionamiento general del sistema.</p>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Las actualizaciones necesarias para estabilidad o corrección de errores estarán incluidas. Las actualizaciones mayores, nuevas herramientas, módulos adicionales o desarrollos personalizados podrán cotizarse por separado.</p>
                </div>
            </div>
            
        </section>

        <!-- Implementación y Pagos -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-10 print-break-inside-avoid">
            <div class="space-y-10">
                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-calendar text-gold-500 text-xl"></i> Tiempo de Implementación
                    </h3>
                    <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 flex items-center gap-5 print:bg-white print:border-slate-200">
                        <div class="bg-dark-900 print:bg-slate-100 p-3 rounded-full text-gold-500">
                            <i class="ph ph-timer text-2xl"></i>
                        </div>
                        <p class="text-sm text-neutral-300 print:text-slate-700 font-medium">De <strong class="text-white print:text-black">2 a 5 días hábiles</strong> posteriores a la confirmación del proyecto y recepción del anticipo.</p>
                    </div>
                </div>
            </div>

            <div class="space-y-10">
                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-wallet text-gold-500 text-xl"></i> Forma de Pago
                    </h3>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center bg-dark-800 p-5 rounded-xl border border-dark-700 print:bg-white print:border-slate-200">
                            <span class="text-sm font-semibold text-neutral-300 print:text-slate-700">50% de anticipo</span>
                            <span class="text-xl font-bold text-gold-400 print:text-black">$3,500 MXN</span>
                        </div>
                        <div class="flex justify-between items-center bg-dark-800 p-5 rounded-xl border border-dark-700 print:bg-white print:border-slate-200">
                            <span class="text-sm font-semibold text-neutral-300 print:text-slate-700">50% contra entrega e instalación</span>
                            <span class="text-xl font-bold text-gold-400 print:text-black">$3,500 MXN</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer / Signature -->
        <footer class="mt-20 pt-10 border-t border-dark-800 text-center print-break-inside-avoid print:border-slate-300">
            <p class="text-neutral-500 print:text-slate-600 italic mb-10">"Agradecemos la oportunidad de colaborar con <strong>Las Quilacas</strong> en la mejora de su operación y control de ventas."</p>
            
            <div class="inline-block text-center">
                <p class="text-sm text-neutral-400 print:text-slate-500 mb-3">Atentamente,</p>
                <div class="w-64 h-px bg-dark-700 print:bg-slate-300 mx-auto my-5"></div> <!-- Línea de firma -->
                <h4 class="text-2xl font-bold text-white print:text-black mb-1">R&G Solutions</h4>
                <p class="text-sm text-gold-500 print:text-slate-600 font-medium">Soluciones Audiovisuales y Tecnológicas</p>
            </div>
        </footer>

    </main>

    <!-- Script para inicializar íconos y fecha -->
    <script is:inline>
        // Establecer fecha estática según la solicitud
        const dateElement = document.getElementById('current-date');
        if (dateElement) {
            dateElement.textContent = 'Fecha: 21 de junio de 2026';
        }
    </script>
</body>
</html>
