---
// index.astro
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cotización - R&G Solutions</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        gold: {
                            400: '#FBBF24',
                            500: '#D4AF37',
                            600: '#B8860B',
                        },
                        brandRed: {
                            500: '#E63946',
                            600: '#DC2626',
                        },
                        dark: {
                            950: '#050505',
                            900: '#0A0A0A',
                            800: '#171717',
                            700: '#262626',
                            600: '#404040',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @media print {
            .no-print {
                display: none !important;
            }
            body {
                background-color: white !important;
                color: black !important;
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
            .print-break-inside-avoid {
                break-inside: avoid;
            }
            @page {
                margin: 1cm;
            }
            /* Override dark mode colors for print */
            .print\:text-slate-900 { color: #0f172a !important; }
            .print\:text-slate-600 { color: #475569 !important; }
            .print\:bg-white { background-color: white !important; }
            .print\:border-slate-200 { border-color: #e2e8f0 !important; }
            .print\:shadow-none { box-shadow: none !important; }
        }
        
        /* Subtle glow effects for the premium feel */
        .glow-gold {
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.15);
        }
        .glow-red {
            box-shadow: 0 0 15px rgba(230, 57, 70, 0.15);
        }
    </style>
</head>
<body class="bg-dark-900 text-neutral-300 font-sans antialiased pb-20">

    <!-- Navbar / Header -->
    <header class="bg-dark-950 text-white py-6 shadow-md border-b border-dark-800 print:bg-white print:text-black print:border-b-2 print:border-black print:shadow-none">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center">
            <div class="flex items-center gap-3">
                <i class="ph ph-devices text-gold-500 text-3xl"></i>
                <div>
                    <h1 class="text-2xl font-bold tracking-tight text-white print:text-black">R&G Solutions</h1>
                    <p class="text-xs text-gold-400 print:text-slate-600 tracking-wider uppercase">Soluciones Audiovisuales y Tecnológicas</p>
                </div>
            </div>
            <div class="mt-4 md:mt-0 text-center md:text-right">
                <p class="text-sm font-medium text-neutral-400 print:text-slate-600" id="current-date"></p>
                <button onclick="window.print()" class="no-print mt-2 inline-flex items-center gap-2 bg-brandRed-600 hover:bg-brandRed-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors print:hidden shadow-lg glow-red">
                    <i class="ph ph-printer text-lg"></i> Imprimir / PDF
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-6xl mx-auto px-6 mt-12 space-y-16 print:space-y-8 print:mt-6">
        
        <!-- Intro -->
        <section class="text-center max-w-3xl mx-auto">
            <h2 class="text-sm font-bold text-gold-500 uppercase tracking-widest mb-3">Propuesta Comercial</h2>
            <h3 class="text-3xl md:text-4xl font-extrabold text-white print:text-black mb-4">Cotización — Sistema Punto de Venta R&G</h3>
            <p class="text-lg text-neutral-400 print:text-slate-600 font-medium mb-8">Solución Operativa Integral para Control y Gestión de Ventas</p>
            
            <div class="bg-dark-800 p-8 rounded-2xl border border-dark-700 text-left print:bg-white print:border-none print:p-0">
                <p class="text-neutral-300 print:text-slate-700 leading-relaxed text-lg">
                    Gracias por considerar nuestro <strong class="text-gold-400 print:text-black">sistema de Punto de Venta R&G Solutions</strong> como parte de la operación de su negocio.<br><br>
                    La presente propuesta está diseñada específicamente para las necesidades operativas de su local, buscando optimizar tiempos, reducir errores y mejorar el control general de ventas e inventario.
                </p>
            </div>
        </section>

        <!-- Objetivos -->
        <section class="print-break-inside-avoid">
            <div class="flex items-center gap-3 mb-8">
                <div class="p-2 bg-dark-800 rounded-lg border border-dark-700 print:border-none print:bg-transparent">
                    <i class="ph ph-crosshair text-gold-500 text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-white print:text-black">Objetivo del Sistema</h3>
            </div>
            <p class="text-neutral-400 print:text-slate-600 mb-6 text-lg">Implementar una solución integral de punto de venta que permita:</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-lightning text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Agilizar el proceso de atención y cobro.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-shield-check text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Reducir errores en pedidos y cuentas.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-graph text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Mejorar el control operativo general del local.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-package text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Llevar un mejor control de inventario y compras.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-chart-bar text-gold-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Obtener reportes y estadísticas de ventas.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-gold-500/50 transition-colors flex items-start gap-4 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-clock text-brandRed-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Optimizar tiempos de operación durante horas pico.</p>
                </div>
                <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 hover:border-brandRed-500/50 transition-colors flex items-start gap-4 lg:col-span-3 print:bg-white print:border-slate-200">
                    <i class="ph-fill ph-trend-down text-brandRed-500 text-xl shrink-0 mt-0.5"></i>
                    <p class="text-sm text-neutral-300 print:text-slate-700">Reducir pérdidas por errores humanos o falta de control.</p>
                </div>
            </div>
        </section>

        <!-- Opciones de Inversión -->
        <section class="print-break-inside-avoid">
            <div class="flex items-center gap-3 mb-8">
                <div class="p-2 bg-dark-800 rounded-lg border border-dark-700 print:border-none print:bg-transparent">
                    <i class="ph ph-credit-card text-gold-500 text-2xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-white print:text-black">Opciones de Inversión</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                
                <!-- Opción 1 -->
                <div class="bg-dark-950 rounded-2xl border border-dark-700 overflow-hidden flex flex-col hover:border-dark-600 transition-colors print:bg-white print:border-slate-200">
                    <div class="p-8 bg-dark-800/50 border-b border-dark-700 text-center print:bg-slate-50 print:border-slate-200">
                        <h4 class="text-xl font-bold text-white print:text-black">Opción 1 — Operación Estándar</h4>
                        <div class="mt-4 flex justify-center items-baseline gap-1">
                            <span class="text-4xl font-extrabold tracking-tight text-gold-400 print:text-slate-900">$22,000</span>
                            <span class="text-sm font-semibold text-neutral-400 print:text-slate-500">MXN</span>
                        </div>
                        <p class="text-xs text-neutral-500 mt-2 uppercase tracking-wider font-semibold">Pago Único</p>
                    </div>
                    
                    <div class="p-8 flex-1 text-sm text-neutral-300 space-y-8 print:text-slate-700">
                        <!-- Software -->
                        <div>
                            <h5 class="font-bold text-white print:text-black mb-3 flex items-center gap-2"><i class="ph ph-desktop text-gold-500 text-lg"></i> Software Punto de Venta R&G</h5>
                            <ul class="space-y-3 ml-7 list-disc marker:text-gold-500">
                                <li>Sistema POS completo.</li>
                                <li>Gestión de ventas, inventario y compras.</li>
                                <li>Catálogo de productos.</li>
                                <li>Reportes y estadísticas.</li>
                                <li>Aplicación comandera.</li>
                                <li><span class="font-semibold text-gold-400 print:text-black">Licencia permanente de uso.</span></li>
                                <li>Sin suscripciones mensuales ni comisiones por venta.</li>
                            </ul>
                        </div>
                        <!-- Hardware -->
                        <div>
                            <h5 class="font-bold text-white print:text-black mb-3 flex items-center gap-2"><i class="ph ph-hard-drive text-gold-500 text-lg"></i> Hardware Incluido</h5>
                            <ul class="space-y-3 ml-7 list-disc marker:text-gold-500">
                                <li>4 tablets operativas.</li>
                                <li>2 impresoras térmicas.</li>
                                <li>1 cajón de dinero.</li>
                                <li>Stand para terminal principal.</li>
                                <li>Funda protectora para tablet principal.</li>
                            </ul>
                        </div>
                        <!-- Servicios -->
                        <div>
                            <h5 class="font-bold text-white print:text-black mb-3 flex items-center gap-2"><i class="ph ph-wrench text-gold-500 text-lg"></i> Servicios Incluidos</h5>
                            <ul class="space-y-3 ml-7 list-disc marker:text-gold-500">
                                <li>Instalación inicial del sistema.</li>
                                <li>Configuración básica.</li>
                                <li>Capacitación inicial al personal.</li>
                                <li>Soporte técnico básico.</li>
                                <li>Actualizaciones necesarias de funcionamiento y estabilidad.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Opción 2 -->
                <div class="bg-dark-950 rounded-2xl border-2 border-gold-500 overflow-hidden flex flex-col relative transform md:-translate-y-2 glow-gold print:bg-white print:border-slate-800 print:shadow-none">
                    <div class="absolute top-0 right-0 bg-gold-500 text-dark-950 text-xs font-bold px-4 py-1.5 rounded-bl-lg uppercase tracking-wider print:text-white print:bg-slate-800">
                        Recomendado
                    </div>
                    <div class="p-8 bg-dark-800 border-b border-dark-700 text-center print:bg-slate-100 print:border-slate-200">
                        <h4 class="text-xl font-bold text-gold-400 print:text-black">Opción 2 — Operación Optimizada</h4>
                        <div class="mt-4 flex justify-center items-baseline gap-1">
                            <span class="text-4xl font-extrabold tracking-tight text-white print:text-black">$25,000</span>
                            <span class="text-sm font-semibold text-gold-400 print:text-slate-600">MXN</span>
                        </div>
                        <p class="text-xs text-gold-500/70 mt-2 uppercase tracking-wider font-semibold print:text-slate-500">Pago Único</p>
                    </div>
                    
                    <div class="p-8 flex-1 text-sm text-neutral-300 space-y-8 print:text-slate-700">
                        <p class="text-gold-100 font-medium bg-gold-500/10 border border-gold-500/20 p-4 rounded-xl flex items-start gap-3 print:bg-slate-50 print:border-slate-200 print:text-slate-800">
                            <i class="ph-fill ph-info text-gold-500 text-xl shrink-0 mt-0.5"></i>
                            Incluye todo lo de la opción estándar, con la siguiente mejora en hardware:
                        </p>
                        <!-- Hardware Mejorado -->
                        <div>
                            <ul class="space-y-4">
                                <li class="flex items-start gap-3">
                                    <i class="ph-fill ph-check-circle text-gold-500 text-xl shrink-0 mt-0.5"></i>
                                    <span class="font-semibold text-white print:text-black text-base">1 tablet principal de 11” para administración y control operativo.</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="ph-fill ph-check-circle text-gold-500 text-xl shrink-0 mt-0.5"></i>
                                    <span class="text-base">3 tablets operativas para atención y comandas.</span>
                                </li>
                            </ul>
                        </div>
                        <!-- Beneficios de mejora -->
                        <div>
                            <h5 class="font-bold text-white print:text-black mb-3 flex items-center gap-2"><i class="ph-fill ph-star text-gold-500 text-lg"></i> Beneficios de esta configuración</h5>
                            <ul class="space-y-3 ml-7 list-disc marker:text-gold-500">
                                <li>Mejor supervisión de ventas y reportes.</li>
                                <li>Mayor comodidad de uso en administración.</li>
                                <li>Mejor visualización de pedidos e inventario.</li>
                                <li>Operación más fluida durante horas de alta demanda.</li>
                            </ul>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Beneficios Operativos -->
        <section class="print-break-inside-avoid bg-gradient-to-br from-dark-800 to-dark-900 border border-dark-700 text-white rounded-3xl p-10 print:bg-white print:text-slate-800 print:border-slate-200 print:bg-none">
            <div class="flex flex-col md:flex-row gap-10 items-center">
                <div class="md:w-1/3">
                    <h3 class="text-3xl font-bold mb-4 text-white print:text-black">Beneficios Operativos</h3>
                    <p class="text-neutral-400 print:text-slate-600 text-base leading-relaxed">
                        Implementar un sistema de punto de venta permite convertir tiempo perdido y errores operativos en <strong class="text-gold-400 print:text-black">productividad y control</strong>.
                    </p>
                </div>
                <div class="md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Reducción de errores en pedidos.</span>
                    </div>
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Mayor rapidez en atención.</span>
                    </div>
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Mejor organización cocina/caja.</span>
                    </div>
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Menor margen de pérdida/mermas.</span>
                    </div>
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Mayor control de ventas diarias.</span>
                    </div>
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Historial y análisis de ventas.</span>
                    </div>
                    <div class="flex items-center gap-3 bg-dark-950/50 print:bg-slate-50 p-4 rounded-xl border border-dark-700/50 print:border-slate-200 transition-colors hover:border-gold-500/30 sm:col-span-2">
                        <i class="ph-fill ph-check-circle text-brandRed-500 text-lg"></i>
                        <span class="text-sm font-medium">Mayor facilidad para supervisar la operación del local.</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Condiciones, Garantías, Pagos -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-10 print-break-inside-avoid">
            
            <!-- Columna Izquierda -->
            <div class="space-y-10">
                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-file-text text-gold-500 text-xl"></i> Condiciones
                    </h3>
                    <ul class="space-y-3 text-sm text-neutral-300 print:text-slate-700">
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>La licencia del sistema es de pago único.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>No existen mensualidades ni comisiones por uso.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Incluye soporte técnico básico remoto.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Actualizaciones mayores o nuevas funciones podrán cotizarse por separado.</li>
                    </ul>
                    
                    <div class="mt-6 bg-dark-800 border border-brandRed-500/30 p-5 rounded-xl text-sm text-neutral-300 print:bg-red-50 print:border-red-100 print:text-slate-800">
                        <p class="font-bold text-brandRed-500 print:text-red-800 mb-2 flex items-center gap-2"><i class="ph-fill ph-warning-circle"></i> Nota sobre Configuración Avanzada</p>
                        <p class="mb-3 text-neutral-400 print:text-slate-700">La configuración avanzada tiene costo adicional e incluye ejemplos como:</p>
                        <ul class="list-disc pl-5 space-y-1.5 text-neutral-400 print:text-slate-700">
                            <li>Alta masiva de productos.</li>
                            <li>Configuración completa de inventario.</li>
                            <li>Carga detallada de recetas o insumos.</li>
                            <li>Ajustes operativos personalizados.</li>
                        </ul>
                    </div>
                </div>

                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-shield-check text-gold-500 text-xl"></i> Garantías
                    </h3>
                    <ul class="space-y-3 text-sm text-neutral-300 print:text-slate-700">
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>Garantía sobre funcionamiento correcto del software.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>El hardware está sujeto a garantía del fabricante.</li>
                        <li class="flex items-start gap-3"><div class="w-1.5 h-1.5 rounded-full bg-gold-500 mt-1.5 shrink-0"></div>No incluye daños por uso indebido, golpes o accidentes.</li>
                    </ul>
                </div>
            </div>

            <!-- Columna Derecha -->
            <div class="space-y-10">
                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-calendar text-gold-500 text-xl"></i> Tiempo de Implementación
                    </h3>
                    <div class="bg-dark-800 p-5 rounded-xl border border-dark-700 flex items-center gap-5 print:bg-white print:border-slate-200">
                        <div class="bg-dark-900 print:bg-slate-100 p-3 rounded-full text-gold-500">
                            <i class="ph ph-timer text-2xl"></i>
                        </div>
                        <p class="text-sm text-neutral-300 print:text-slate-700 font-medium">De <strong class="text-white print:text-black">3 a 7 días hábiles</strong> posteriores a anticipo y confirmación del proyecto.</p>
                    </div>
                </div>

                <div>
                    <h3 class="text-xl font-bold text-white print:text-black border-b border-dark-700 print:border-slate-300 pb-3 mb-5 flex items-center gap-3">
                        <i class="ph ph-wallet text-gold-500 text-xl"></i> Forma de Pago
                    </h3>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center bg-dark-800 p-5 rounded-xl border border-dark-700 print:bg-white print:border-slate-200">
                            <span class="text-sm font-semibold text-neutral-300 print:text-slate-700">Anticipo (Inicio y hardware)</span>
                            <span class="text-xl font-bold text-gold-400 print:text-black">50%</span>
                        </div>
                        <div class="flex justify-between items-center bg-dark-800 p-5 rounded-xl border border-dark-700 print:bg-white print:border-slate-200">
                            <span class="text-sm font-semibold text-neutral-300 print:text-slate-700">Contra entrega e instalación</span>
                            <span class="text-xl font-bold text-gold-400 print:text-black">50%</span>
                        </div>
                    </div>
                </div>
            </div>
            
        </section>

        <!-- Footer / Signature -->
        <footer class="mt-20 pt-10 border-t border-dark-800 text-center print-break-inside-avoid print:border-slate-300">
            <p class="text-neutral-500 print:text-slate-600 italic mb-10">"Agradecemos la oportunidad de colaborar en la optimización operativa de su negocio."</p>
            
            <div class="inline-block text-center">
                <p class="text-sm text-neutral-400 print:text-slate-500 mb-3">Atentamente,</p>
                <div class="w-64 h-px bg-dark-700 print:bg-slate-300 mx-auto my-5"></div> <!-- Línea de firma -->
                <h4 class="text-2xl font-bold text-white print:text-black mb-1">R&G Solutions</h4>
                <p class="text-sm text-gold-500 print:text-slate-600 font-medium">Soluciones Audiovisuales y Tecnológicas</p>
            </div>
        </footer>

    </main>

    <!-- Script para inicializar íconos y fecha -->
    <script>
        // Establecer fecha actual
        const dateOptions = { year: 'numeric', month: 'long', day: 'numeric' };
        const currentDate = new Date().toLocaleDateString('es-MX', dateOptions);
        const dateElement = document.getElementById('current-date');
        if (dateElement) {
            dateElement.textContent = 'Fecha: ' + currentDate;
        }
    </script>
</body>
